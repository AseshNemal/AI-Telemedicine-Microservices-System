# ==========================================
# AI Telemedicine Microservices - ENV EXAMPLE
# ==========================================
# Copy this file to .env and fill in real values.
# DO NOT commit your real .env file.

# Database
DATABASE_URL="<your-mongodb-connection-string>"

# Service ports
AUTH_PORT=8081
PATIENT_PORT=5002
DOCTOR_PORT=8082
APPOINTMENT_PORT=8083
NOTIFICATION_PORT=8084
PAYMENT_PORT=8085

# Internal service communication
NOTIFICATION_SERVICE_URL=http://notification-service:8084
PATIENT_SERVICE_URL=http://localhost:5002
INTERNAL_SERVICE_KEY=<generate-a-long-random-secret>

# Frontend -> backend URLs (browser)
NEXT_PUBLIC_AUTH_SERVICE_URL=http://localhost:8081
NEXT_PUBLIC_PATIENT_SERVICE_URL=http://localhost:5002
NEXT_PUBLIC_DOCTOR_SERVICE_URL=http://localhost:8082
NEXT_PUBLIC_APPOINTMENT_SERVICE_URL=http://localhost:8083
NEXT_PUBLIC_PAYMENT_SERVICE_URL=http://localhost:8085

# Option A (recommended): mounted JSON path (local, Docker, K8s volume mount)
FIREBASE_SERVICE_ACCOUNT_PATH=./secrets/firebase-service-account.json

# Option B (fallback): env-field credentials
FIREBASE_PROJECT_ID="<your-firebase-project-id>"
FIREBASE_CLIENT_EMAIL="<your-firebase-client-email>"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n<your-private-key-with-escaped-newlines>\n-----END PRIVATE KEY-----\n"
FIREBASE_WEB_API_KEY="<your-firebase-web-api-key>"
NEXT_PUBLIC_FIREBASE_API_KEY="<your-firebase-web-api-key>"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="<your-firebase-project-id>"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="<your-firebase-project-id>.firebaseapp.com"

# Google OAuth (for frontend login)
Web_client_ID=<your-google-oauth-web-client-id>
Web_client_secret=<your-google-oauth-web-client-secret>

# Stripe
STRIPE_SECRET_KEY="<your-stripe-secret-key>"
STRIPE_WEBHOOK_SECRET="<your-stripe-webhook-secret>"
STRIPE_PUBLIC_KEY="<your-stripe-public-key>"
NEXT_PUBLIC_PAYMENT_SERVICE_URL=http://localhost:8085

# OpenAI
OPENAI_API_KEY=<your-openai-api-key>
OPENAI_MODEL=gpt-4o-mini

# Twilio and SendGrid (for notifications)
TWILIO_ACCOUNT_SID="<your-twilio-account-sid>"
TWILIO_AUTH_TOKEN="<your-twilio-auth-token>"
TWILIO_PHONE_NUMBER="<your-twilio-phone-number>"

SENDGRID_API_KEY="<your-sendgrid-api-key>"
SENDGRID_SENDER_EMAIL="<your-sender-email>"

# LiveKit API Key (for live chat support)
LIVEKIT_API_KEY="<your-livekit-api-key>"
LIVEKIT_API_SECRET="<your-livekit-api-secret>"
LIVEKIT_URL="<your-livekit-url>"
