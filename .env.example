# Shared database
DATABASE_URL=mongodb+srv://<username>:<password>@<cluster>/<database>?retryWrites=true&w=majority

# Service ports
AUTH_PORT=8081
DOCTOR_PORT=8082
APPOINTMENT_PORT=8083
NOTIFICATION_PORT=8084

# Internal service communication
NOTIFICATION_SERVICE_URL=http://notification-service:8084

# Frontend -> backend URLs (browser)
NEXT_PUBLIC_AUTH_SERVICE_URL=http://localhost:8081
NEXT_PUBLIC_DOCTOR_SERVICE_URL=http://localhost:8082
NEXT_PUBLIC_APPOINTMENT_SERVICE_URL=http://localhost:8083
